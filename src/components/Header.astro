---
import { contactHref, navLinks, siteName } from "../config/site";
import Button from "./ui/Button.astro";
import Container from "./ui/Container.astro";
---

<header class="border-b border-border bg-surface/90">
  <Container class="flex min-h-20 flex-wrap items-center justify-between gap-4 py-4">
    <a href="/" class="inline-flex items-center gap-3 no-underline" aria-label={`${siteName} home`}>
      <span class="flex size-10 items-center justify-center rounded-md bg-brand text-white shadow-soft" aria-hidden="true">
        <svg viewBox="0 0 24 24" class="size-6">
          <path d="M6.4 17 11 6h2l4.6 11h-2.5l-.8-2.2H9.6L8.8 17H6.4Zm3.9-4.2h3.3L12 8.5l-1.7 4.3Z" fill="currentColor" />
        </svg>
      </span>
      <span class="text-base font-semibold text-ink sm:text-lg">{siteName}</span>
    </a>

    <nav class="flex flex-wrap items-center justify-end gap-2 sm:gap-4" aria-label="Primary navigation">
      {
        navLinks.map((link) =>
          link.href === contactHref ? (
            <Button href={link.href} variant="secondary" size="sm">
              {link.label}
            </Button>
          ) : (
            <a class="rounded-md px-3 py-2 text-sm font-semibold no-underline text-ink-muted hover:text-brand-strong" href={link.href}>
              {link.label}
            </a>
          )
        )
      }
    </nav>
  </Container>
</header>
