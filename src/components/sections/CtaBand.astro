---
import { contactHref, siteDescription } from "../../config/site";
import Button from "../ui/Button.astro";
import Container from "../ui/Container.astro";

const ctaLabel = "Email us";
---

<section id="contact" class="bg-brand py-16 text-white sm:py-20">
  <Container width="lg" class="flex flex-col items-start gap-8 md:flex-row md:items-center md:justify-between">
    <div class="max-w-3xl">
      <h2 class="text-3xl font-semibold text-white sm:text-5xl">
        {siteDescription}
      </h2>
      <p class="mt-4 max-w-2xl text-lg text-white/85">
        Share what you want to build, and start the work with a direct contact thread.
      </p>
    </div>
    <Button href={contactHref} variant="secondary" size="lg" class="w-full shrink-0 sm:w-auto">
      {ctaLabel}
    </Button>
  </Container>
</section>
