---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Agent Team for Founders";
const description = "You just talk, we handle the rest";
---

<BaseLayout title={title} description={description}>
  <main class="mx-auto flex min-h-screen max-w-5xl flex-col items-start justify-center px-6 py-16 sm:px-8">
    <h1 class="max-w-3xl text-5xl font-semibold text-balance text-ink sm:text-6xl">
      {title}
    </h1>
    <p class="mt-6 max-w-2xl text-xl text-ink-muted">
      {description}
    </p>
  </main>
</BaseLayout>
